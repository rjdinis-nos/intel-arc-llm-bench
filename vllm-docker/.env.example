# vLLM Server Configuration (copy to .env)

# ── Model ──────────────────────────────────────────────────────────────
# HuggingFace model ID to serve.
MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct

# Data type. bfloat16 is recommended on Intel Arc (Xe2 XMX engines).
DTYPE=bfloat16

# Context window. Lower this if you hit out-of-memory on a small iGPU.
MAX_MODEL_LEN=2048

# ── Serving ────────────────────────────────────────────────────────────
# Host port mapped to the container's :8000.
VLLM_PORT=8000

# Fraction of GPU memory vLLM may reserve (0.0-1.0).
GPU_MEMORY_UTILIZATION=0.9

# Number of GPUs for tensor parallelism (1 for a single Arc iGPU/dGPU).
TENSOR_PARALLEL_SIZE=1

# Shared memory for the container (vLLM needs more than Docker's 64MB default).
SHM_SIZE=4gb

# Extra raw args appended to `vllm serve` (bare flags only).
# Example: EXTRA_ARGS=--disable-log-requests --max-num-seqs 16
EXTRA_ARGS=

# ── Build / image ──────────────────────────────────────────────────────
# vLLM source tag to build the XPU image from (see `make build`).
VLLM_REF=v0.22.0
# Image tag used by docker-compose (must match what `make build` produces).
VLLM_IMAGE=vllm-xpu:v0.22.0

# ── HuggingFace ────────────────────────────────────────────────────────
# Token for gated models (e.g. meta-llama/*). Leave empty for open models.
HUGGING_FACE_HUB_TOKEN=

# ── Native-Linux DRI override (ignored on WSL2) ────────────────────────
# Override only if `render`/`video` group names don't exist in the container.
# RENDER_GID=993
# VIDEO_GID=44
